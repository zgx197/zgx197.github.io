---
// 极简博客首页
const posts = await Astro.glob('../content/blog/*.md');

// 排序：最新在前
const sortedPosts = posts
  .sort((a, b) => new Date(b.frontmatter.date || 0) - new Date(a.frontmatter.date || 0));

// 获取所有标签
const allTags = [...new Set(sortedPosts.flatMap(post => post.frontmatter.tags || []))];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>zgx197</title>
  <meta name="description" content="个人博客">
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.6;
      color: #333;
      max-width: 720px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    header {
      margin-bottom: 40px;
      padding-bottom: 20px;
      border-bottom: 1px solid #eee;
    }
    h1 {
      font-size: 20px;
      font-weight: 600;
      color: #000;
    }
    
    /* 搜索框 */
    #search {
      margin-bottom: 40px;
    }
    
    /* 文章列表 */
    .post-list {
      list-style: none;
    }
    .post-item {
      margin-bottom: 24px;
      padding-bottom: 24px;
      border-bottom: 1px solid #f0f0f0;
    }
    .post-item:last-child {
      border-bottom: none;
    }
    .post-title {
      font-size: 16px;
      font-weight: 500;
      margin-bottom: 6px;
    }
    .post-title a {
      color: #000;
      text-decoration: none;
    }
    .post-title a:hover {
      color: #0066cc;
    }
    .post-meta {
      font-size: 13px;
      color: #666;
    }
    .post-date {
      color: #999;
    }
    .post-tag {
      margin-left: 8px;
      color: #0066cc;
    }
    .post-tag::before {
      content: "#";
    }
    
    /* 空状态 */
    .empty {
      color: #999;
      font-size: 14px;
      padding: 40px 0;
    }
    
    /* 页脚 */
    footer {
      margin-top: 60px;
      padding-top: 20px;
      border-top: 1px solid #eee;
      font-size: 12px;
      color: #999;
    }
  </style>
</head>
<body>
  <header>
    <h1>zgx197</h1>
  </header>

  <!-- 搜索 -->
  <div id="search"></div>

  <!-- 文章列表 -->
  <ul class="post-list">
    {sortedPosts.length === 0 ? (
      <li class="empty">暂无文章</li>
    ) : (
      sortedPosts.map(post => (
        <li class="post-item">
          <h2 class="post-title">
            <a href={post.url}>{post.frontmatter.title}</a>
          </h2>
          <div class="post-meta">
            <span class="post-date">
              {new Date(post.frontmatter.date).toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit'
              }).replace(/\//g, '-')}
            </span>
            {post.frontmatter.tags?.map(tag => (
              <span class="post-tag">{tag}</span>
            ))}
          </div>
        </li>
      ))
    )}
  </ul>

  <footer>
    <p>Minimal blog powered by Astro</p>
  </footer>

  <!-- Pagefind搜索 -->
  <script src="/pagefind/pagefind-ui.js"></script>
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: "#search",
        placeholder: "搜索...",
        showImages: false,
        translations: {
          placeholder: "搜索...",
          zero_results: "无结果",
          many_results: "# 个结果",
          one_result: "1 个结果"
        }
      });
    });
  </script>
</body>
</html>
