---
// 文章详情页 - 极简风格
export async function getStaticPaths() {
  const posts = await Astro.glob('../../content/blog/*.md');
  
  return posts.map(post => ({
    params: { 
      slug: post.file.split('/').pop().replace('.md', '') 
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = post;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{post.frontmatter.title}</title>
  <meta name="description" content={post.frontmatter.description}>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.8;
      color: #333;
      max-width: 720px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    
    /* 导航 */
    nav {
      margin-bottom: 40px;
    }
    nav a {
      color: #666;
      text-decoration: none;
      font-size: 14px;
    }
    nav a:hover {
      color: #0066cc;
    }
    
    /* 搜索 */
    #search {
      margin-bottom: 40px;
    }
    
    /* 文章头部 */
    header {
      margin-bottom: 40px;
      padding-bottom: 30px;
      border-bottom: 1px solid #eee;
    }
    h1 {
      font-size: 24px;
      font-weight: 600;
      color: #000;
      margin-bottom: 12px;
      line-height: 1.4;
    }
    .meta {
      font-size: 13px;
      color: #666;
    }
    .meta .date {
      color: #999;
    }
    .meta .tag {
      margin-left: 8px;
      color: #0066cc;
    }
    .meta .tag::before {
      content: "#";
    }
    
    /* 文章内容 */
    article {
      font-size: 16px;
    }
    article h2 {
      font-size: 20px;
      font-weight: 600;
      margin: 32px 0 16px;
      color: #000;
    }
    article h3 {
      font-size: 18px;
      font-weight: 600;
      margin: 24px 0 12px;
      color: #000;
    }
    article p {
      margin-bottom: 16px;
    }
    article ul, article ol {
      margin: 16px 0;
      padding-left: 24px;
    }
    article li {
      margin-bottom: 8px;
    }
    article a {
      color: #0066cc;
      text-decoration: none;
    }
    article a:hover {
      text-decoration: underline;
    }
    article code {
      background: #f5f5f5;
      padding: 2px 6px;
      border-radius: 3px;
      font-family: monospace;
      font-size: 14px;
    }
    article pre {
      background: #f5f5f5;
      padding: 16px;
      border-radius: 6px;
      overflow-x: auto;
      margin: 16px 0;
    }
    article pre code {
      background: none;
      padding: 0;
    }
    article blockquote {
      border-left: 3px solid #ddd;
      padding-left: 16px;
      margin: 16px 0;
      color: #666;
    }
    article img {
      max-width: 100%;
      height: auto;
    }
    
    /* 返回底部 */
    .back {
      margin-top: 60px;
      padding-top: 20px;
      border-top: 1px solid #eee;
    }
    .back a {
      color: #666;
      text-decoration: none;
      font-size: 14px;
    }
    .back a:hover {
      color: #0066cc;
    }
  </style>
</head>
<body>
  <nav>
    <a href="/">← 返回</a>
  </nav>

  <!-- 搜索 -->
  <div id="search"></div>

  <!-- 文章 -->
  <article>
    <header>
      <h1>{post.frontmatter.title}</h1>
      <div class="meta">
        <span class="date">
          {new Date(post.frontmatter.date).toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit'
          }).replace(/\//g, '-')}
        </span>
        {post.frontmatter.tags?.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </header>

    <Content />
  </article>

  <div class="back">
    <a href="/">← 返回文章列表</a>
  </div>

  <!-- Pagefind搜索 -->
  <script src="/pagefind/pagefind-ui.js"></script>
  <script>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: "#search",
        placeholder: "搜索...",
        showImages: false,
        translations: {
          placeholder: "搜索...",
          zero_results: "无结果",
          many_results: "# 个结果",
          one_result: "1 个结果"
        }
      });
    });
  </script>
</body>
</html>
